# Cosmosphere Environment Variables
# Copy this to .env and fill in values

# Optional: N2YO API key for enhanced satellite data
VITE_N2YO_API_KEY=your_n2yo_api_key_here

# CORS proxy URL (default uses allorigins.win for development)
VITE_CORS_PROXY=https://api.allorigins.win/raw?url=

# CelesTrak base URL
VITE_CELESTRAK_BASE=https://celestrak.org/SATCAT/TLE/
